import { Button, LineEdit, Switch } from "std-widgets.slint";

export struct BluetoothDevice {
    name: string,
    mac_address: string,
    connected: bool,
}

export component AppWindow inherits Window {
    callback refresh-networks();
    callback connect(ssid: string);
    callback connect-new(ssid: string, password: string);
    callback disconnect(ssid: string);
    callback forget(ssid: string);
    callback show-password-popup();
    callback toggle-bluetooth();
    callback toggle-wifi();
    property <bool> bluetooth: false;
    in property <string> curnet;
    in property <[string]> networks;
    in property <[string]> avail-networks;
    in property <[BluetoothDevice]> saved-devices;
    in property <bool> wifi-on: false;
    in property <bool> bluetooth-on: false;
    in-out property <string> pending-ssid;
    in-out property <bool> password-error: false;
    in-out property <string> password-error-text: "";

    VerticalLayout {
        padding: 20px;
        alignment: center;
        HorizontalLayout {
            padding: 10px;
            spacing: 5px;
            alignment: center;

            Button {
                width: 100px;
                height: 30px;
                text: "Network";
                clicked => { root.bluetooth = false; }
            }

            Button {
                width: 100px;
                height: 30px;
                text: "Bluetooth";
                clicked => { root.bluetooth = true; }
            }
        }

        if !root.bluetooth : VerticalLayout {
            padding: 15px;
            spacing: 10px;
            Switch {
              text: "Wifi";
              checked: root.wifi-on;
              toggled() => {
                toggle-wifi();
              }
            }
            if root.wifi-on : VerticalLayout{
            Text {
                font-size: 20px;
                text: "Current Network";
            }

            if root.curnet != "None" : VerticalLayout {
                HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: curnet;
                    }
                    Button {
                        width: 100px;
                        text: "Disconnect";
                        clicked => { root.disconnect(curnet); }
                    }
                    Button {
                        width: 75px;
                        text: "Forget";
                        clicked => { root.forget(curnet); }
                    }
                }
            }

            if root.curnet == "None" : VerticalLayout {
                Text {
                  font-size: 12px;
                  text: "You are not currently connected to a network";
                }
            }

            Button {
                width: 80px;
                text: "Refresh";
                clicked => { root.refresh-networks(); }
            }

            Text {
                font-size: 20px;
                text: "Other Networks";
            }
            VerticalLayout {
                for net in avail-networks :
                    HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: net;
                    }
                    Button {
                        width: 80px;
                        text: "Connect";
                        clicked => { connect(net); }
                    }
                }
            }


            Text {
                font-size: 20px;
                text: "Saved Networks";
            }
            VerticalLayout {
                for net in networks :
                    HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: net;
                    }
                    Button {
                        width: 80px;
                        text: "Forget";
                        clicked => { root.forget(net); }

                    }
                }
            }
          }
        }

        if root.bluetooth : VerticalLayout {
             padding: 15px;
            spacing: 10px;
            Switch {
              text: "Bluetooth";
              checked: root.bluetooth-on;
              toggled() => {
                toggle-bluetooth();
              }
            }
            if root.bluetooth-on : VerticalLayout {
            Text {
                text: "Saved Devices";
            }
            VerticalLayout{
              for device in saved-devices :

            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: device.name;
                }
                Button {
                    width: 80px;
                    text: "Forget";
                }
                Button {
                    width: 80px;
                    text: "Connect";
                }
              }
            }
            Text {
                text: "Other Devices";
            }
            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "Device";
                }
                Button {
                    width: 80px;
                    text: "Connect";
                }
            }
            Button {
                text: "Refresh";
            }
            }
        }
    }

    password-popup := PopupWindow {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 250px;
        height: 130px;
        close-policy: close-on-click-outside;
        forward-focus: password-input;

        function submit-password(password: string) {
            root.connect-new(root.pending-ssid, password);
            if (!root.password-error) {
              password-popup.close();
            }
        }

        Rectangle {
            background: white;
            border-width: 1px;
            border-color: gray;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                Text {
                    text: "Enter password for " + root.pending-ssid;
                    wrap: word-wrap;
                }

                password-input := LineEdit {
                    input-type: password;
                    accepted(text) => { submit-password(text); }
                }

                if root.password-error : Text {
                    text: root.password-error-text;
                    color: red;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                Button {
                    text: "Connect";
                    clicked => { submit-password(password-input.text); }
                }
            }
        }
    }

    show-password-popup => {
        password-popup.show();
    }
}
